Python
import os
import datetime
import numpy as np
import tensorflow as tf
from tensorflow.keras.models import Sequential, Model
from tensorflow.keras.layers import (Conv2D, MaxPooling2D, Flatten, Dense, 
                                     Dropout, TimeDistributed, LSTM, LeakyReLU, Reshape, Conv2DTranspose, Input)

# Configurări globale din scriptul tău
IMG_SHAPE = (224, 224, 3)
STEPS_PER_VIDEO = 25 # Numărul de cadre extrase per video

# ==============================================================================
# 1. GAN COMPLET (Generator + Discriminator)
# În timp ce Generatorul învață să creeze fețe deepfake artificiale, 
# Discriminatorul devine din ce în ce mai bun la detecția lor.
# ==============================================================================
print("\n--- Inițializare GAN Complet ---")

def build_generator():
    # Primește un vector de zgomot aleatoriu de dimensiune 100 și generează o imagine 224x224x3
    model = Sequential([
        Dense(7 * 7 * 256, input_dim=100),
        LeakyReLU(alpha=0.2),
        Reshape((7, 7, 256)),
        
        # Upsampling treptat până la 224x224
        Conv2DTranspose(128, (4,4), strides=(2,2), padding='same'), # 14x14
        LeakyReLU(alpha=0.2),
        
        Conv2DTranspose(64, (4,4), strides=(2,2), padding='same'),  # 28x28
        LeakyReLU(alpha=0.2),
        
        Conv2DTranspose(32, (4,4), strides=(2,2), padding='same'),  # 56x56
        LeakyReLU(alpha=0.2),
        
        Conv2DTranspose(16, (4,4), strides=(2,2), padding='same'),  # 112x112
        LeakyReLU(alpha=0.2),
        
        Conv2DTranspose(3, (4,4), strides=(2,2), padding='same', activation='tanh') # 224x224x3
    ], name="Generator")
    return model

def build_discriminator():
    # Discriminatorul este detectorul tău de deepfake la nivel de cadru
    model = Sequential([
        Conv2D(64, (3,3), strides=(2,2), padding="same", input_shape=IMG_SHAPE),
        LeakyReLU(alpha=0.2),
        Dropout(0.3),
        
        Conv2D(128, (3,3), strides=(2,2), padding="same"),
        LeakyReLU(alpha=0.2),
        Dropout(0.3),
        
        Flatten(),
        Dense(1, activation="sigmoid") # 1 = Real, 0 = Fake (Generat/Deepfake)
    ], name="Discriminator")
    return model

generator = build_generator()
discriminator = build_discriminator()

# Configurare Log-uri TensorBoard pentru bucla custom de GAN
gan_log_dir = "logs/fit/gan_complete_" + datetime.datetime.now().strftime("%Y%m%d-%H%M%S")
summary_writer = tf.summary.create_file_writer(gan_log_dir)

# Optimizatori și Loss pentru GAN
cross_entropy = tf.keras.losses.BinaryCrossentropy()
generator_optimizer = tf.keras.optimizers.Adam(1e-4)
discriminator_optimizer = tf.keras.optimizers.Adam(1e-4)

@tf.function
def train_gan_step(real_images):
    noise = tf.random.normal([real_images.shape[0], 100])

    with tf.GradientTape() as gen_tape, tf.GradientTape() as disc_tape:
        generated_images = generator(noise, training=True)

        real_output = discriminator(real_images, training=True)
        fake_output = discriminator(generated_images, training=True)

        # Calcul pierderi (Loss)
        disc_loss_real = cross_entropy(tf.ones_like(real_output), real_output)
        disc_loss_fake = cross_entropy(tf.zeros_like(fake_output), fake_output)
        disc_loss = disc_loss_real + disc_loss_fake
        
        gen_loss = cross_entropy(tf.ones_like(fake_output), fake_output)

    # Aplicare gradienți
    gradients_of_generator = gen_tape.gradient(gen_loss, generator.trainable_variables)
    gradients_of_discriminator = disc_tape.gradient(disc_loss, discriminator.trainable_variables)

    generator_optimizer.apply_gradients(zip(gradients_of_generator, generator.trainable_variables))
    discriminator_optimizer.apply_gradients(zip(gradients_of_discriminator, discriminator.trainable_variables))
    
    return gen_loss, disc_loss


# 2. LSTM PUR (Fără straturi Convoluționale intermediare)
# Tratează imaginile direct ca vectori mari de pixeli aplatizați de-a lungul timpului.
# ==============================================================================
print("\n--- Inițializare LSTM Pur ---")

model_lstm_pure = Sequential([
    # Inputul: 25 de cadre, fiecare cadru este aplatizat complet (224 * 224 * 3 = 150528 pixeli)
    # Notă: Această rețea consumă multă memorie RAM/VRAM din cauza dimensiunii mari a inputului direct
    Input(shape=(STEPS_PER_VIDEO, 224 * 224 * 3)),
    
    LSTM(128, return_sequences=True),
    Dropout(0.3),
    LSTM(64, return_sequences=False),
    Dropout(0.3),
    
    Dense(64, activation="relu"),
    Dense(1, activation="sigmoid")
])

model_lstm_pure.compile(optimizer="adam", loss="binary_crossentropy", metrics=["accuracy"])

log_dir_lstm_pure = "logs/fit/lstm_pure_" + datetime.datetime.now().strftime("%Y%m%d-%H%M%S")
tb_lstm_pure = tf.keras.callbacks.TensorBoard(log_dir=log_dir_lstm_pure, histogram_freq=1)


# ==============================================================================
# 3. COMBINAȚIE AVANSATĂ: CNN Preantrenat (MobileNetV2) + LSTM
# În loc să antrenăm un CNN de la zero (care poate fi slab), folosim MobileNetV2 
# (blocat) ca extractor de caracteristici, iar LSTM-ul învață doar tranzițiile video.
# ==============================================================================
print("\n--- Inițializare Combinație MobileNetV2 + LSTM ---")

# Încărcăm MobileNetV2 fără partea de clasificare finală
base_cnn = tf.keras.applications.MobileNetV2(input_shape=IMG_SHAPE, include_top=False, weights="imagenet")
base_cnn.trainable = False # Înghețăm straturile pentru a nu distruge greutățile preantrenate

model_pretrained_lstm = Sequential([
    # Rulăm MobileNetV2 pe fiecare din cele 25 de cadre
    TimeDistributed(base_cnn, input_shape=(STEPS_PER_VIDEO, 224, 224, 3)),
    TimeDistributed(Flatten()),
    
    # Trimitem vectorii rezultați direct în structura temporală
    LSTM(128, return_sequences=False),
    
    Dense(64, activation="relu"),
    Dropout(0.5),
    Dense(1, activation="sigmoid")
])

model_pretrained_lstm.compile(optimizer="adam", loss="binary_crossentropy", metrics=["accuracy"])

log_dir_pretrained = "logs/fit/pretrained_cnn_lstm_" + datetime.datetime.now().strftime("%Y%m%d-%H%M%S")
tb_pretrained = tf.keras.callbacks.TensorBoard(log_dir=log_dir_pretrained, histogram_freq=1)

